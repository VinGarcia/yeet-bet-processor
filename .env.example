# Copy to .env and adjust for local development.
# The integration tests use testcontainers, NOT this database.
#
# DATABASE_URL is used by host-side tools (the API in `pnpm dev`, seed,
# gamerunner, bench). Inside docker compose the API talks to the `db` service
# directly (see the override in docker-compose.yml), so this localhost URL only
# needs to match DB_HOST_PORT below.
DATABASE_URL=postgres://postgres:postgres@localhost:5132/yeet
PORT=3000
HMAC_SECRET=test

# Host port the compose `db` service publishes (container is always 5432).
# Defaulted off 5432 so it doesn't clash with a local Postgres; bump again if
# 5132 is also taken, and keep DATABASE_URL's port in sync.
DB_HOST_PORT=5132
